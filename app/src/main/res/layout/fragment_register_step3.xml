<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <!-- Phone Display -->
    <TextView
        android:id="@+id/tv_phone_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phone: +1234567890"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <!-- Send SMS Code Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_send_sms_code"
        style="@style/Widget.JobLinker.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send SMS Code"
        android:layout_marginBottom="16dp" />

    <!-- Verification Icon -->
    <ImageView
        android:id="@+id/iv_verification_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_email"
        android:contentDescription="@string/email"
        app:tint="@color/primary"
        android:layout_marginBottom="@dimen/spacing_large"/>

    <TextView
        android:id="@+id/tv_sms_verification_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verification message will appear here"
        android:textSize="14sp" />

    <!-- Verification Title -->
    <TextView
        android:id="@+id/tv_verification_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/verify_your_email"
        style="@style/TextAppearance.JobLinker.HeadlineMedium"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_marginBottom="@dimen/spacing_small"/>

    <!-- Verification Message -->
    <TextView
        android:id="@+id/tv_verification_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="We've sent a verification code to your email. Please check your inbox."
        style="@style/TextAppearance.JobLinker.BodyMedium"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_marginBottom="@dimen/spacing_large"/>

    <!-- SMS Verification Code Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_sms_verification_code"
        style="@style/Widget.JobLinker.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:hint="@string/verification_code"
        app:startIconDrawable="@drawable/ic_code">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_sms_verification_code"
            style="@style/Widget.JobLinker.TextInputEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="6"
            android:gravity="center"
            android:textSize="20sp"
            android:letterSpacing="0.3"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Resend SMS Section -->
    <LinearLayout
        android:id="@+id/layout_resend_sms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_small"
        android:layout_marginBottom="@dimen/spacing_medium">

        <TextView
            android:id="@+id/tv_resend_sms_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/resend_code"
            style="@style/TextAppearance.JobLinker.BodyMedium"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:paddingStart="@dimen/spacing_xs"
            android:paddingEnd="@dimen/spacing_xs"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tv_sms_resend_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            style="@style/TextAppearance.JobLinker.LabelSmall"
            android:textColor="@color/text_hint"/>

    </LinearLayout>

    <!-- Verify SMS Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_verify_sms"
        style="@style/Widget.JobLinker.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/spacing_large"
        android:text="@string/verify"/>

    <!-- Skip SMS Verification Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_skip_sms_verification"
        style="@style/Widget.JobLinker.Button.Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_small"
        android:text="@string/skip"
        android:textColor="@color/text_secondary"/>

    <!-- Complete Registration Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_complete_registration"
        style="@style/Widget.JobLinker.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/spacing_large"
        android:text="@string/complete_registration"/>

</LinearLayout>