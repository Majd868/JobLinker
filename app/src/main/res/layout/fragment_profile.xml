<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/background"
            android:padding="@dimen/spacing_large"
            android:gravity="center_horizontal">

            <!-- Profile Avatar -->
            <FrameLayout
                android:layout_width="@dimen/avatar_size_large"
                android:layout_height="@dimen/avatar_size_large">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person_placeholder"
                    app:shapeAppearanceOverlay="@style/CircularShape"
                    tools:src="@tools:sample/avatars"/>

                <!-- Online Indicator -->
                <View
                    android:id="@+id/view_online"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/ic_online_indicator"/>

            </FrameLayout>

            <!-- User Name -->
            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_medium"
                style="@style/TextAppearance.JobLinker.HeadlineMedium"
                tools:text="John Doe"/>

            <!-- Role Badge -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_role"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                app:chipBackgroundColor="@color/primary"
                android:textColor="@color/text_white"
                tools:text="Job Seeker"/>

            <!-- Stats Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_large"
                android:gravity="center">

                <!-- Jobs Count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_jobs_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.JobLinker.HeadlineSmall"
                        tools:text="12"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/jobs"
                        style="@style/TextAppearance.JobLinker.BodyMedium"
                        android:layout_marginTop="@dimen/spacing_xs"/>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:background="@color/divider"/>

                <!-- Rating -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.JobLinker.HeadlineSmall"
                        tools:text="4.8"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="rating"
                        style="@style/TextAppearance.JobLinker.BodyMedium"
                        android:layout_marginTop="@dimen/spacing_xs"/>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:background="@color/divider"/>

                <!-- Connections -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_connections_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.JobLinker.HeadlineSmall"
                        tools:text="245"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="connections"
                        style="@style/TextAppearance.JobLinker.BodyMedium"
                        android:layout_marginTop="@dimen/spacing_xs"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- User Info Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/background"
            android:layout_marginTop="@dimen/spacing_small"
            android:padding="@dimen/spacing_medium">

            <!-- Location -->
            <LinearLayout
                android:id="@+id/layout_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_medium"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/icon_size"
                    android:layout_height="@dimen/icon_size"
                    android:src="@drawable/ic_location"
                    android:contentDescription="@string/country"
                    app:tint="@color/secondary"/>

                <TextView
                    android:id="@+id/tv_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_medium"
                    style="@style/TextAppearance.JobLinker.BodyLarge"
                    tools:text="San Francisco, USA"/>

            </LinearLayout>

            <!-- Email -->
            <LinearLayout
                android:id="@+id/layout_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_medium"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/icon_size"
                    android:layout_height="@dimen/icon_size"
                    android:src="@drawable/ic_email"
                    android:contentDescription="@string/email"
                    app:tint="@color/secondary"/>

                <TextView
                    android:id="@+id/tv_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_medium"
                    style="@style/TextAppearance.JobLinker.BodyLarge"
                    android:textColor="@color/primary"
                    tools:text="john.doe@example.com"/>

            </LinearLayout>

            <!-- Phone -->
            <LinearLayout
                android:id="@+id/layout_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_medium"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/icon_size"
                    android:layout_height="@dimen/icon_size"
                    android:src="@drawable/ic_phone"
                    android:contentDescription="@string/phone"
                    app:tint="@color/secondary"/>

                <TextView
                    android:id="@+id/tv_phone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_medium"
                    style="@style/TextAppearance.JobLinker.BodyLarge"
                    android:textColor="@color/primary"
                    tools:text="+1 234 567 8900"/>

            </LinearLayout>

            <!-- Bio -->
            <TextView
                android:id="@+id/tv_bio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_medium"
                style="@style/TextAppearance.JobLinker.BodyLarge"
                android:textStyle="italic"
                tools:text="Passionate software engineer with 5+ years of experience in mobile development."/>

            <!-- Skills (For Job Seekers) -->
            <LinearLayout
                android:id="@+id/layout_skills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/skills"
                    style="@style/TextAppearance.JobLinker.LabelLarge"
                    android:layout_marginBottom="@dimen/spacing_small"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_skills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/background"
            android:layout_marginTop="@dimen/spacing_small"
            android:padding="@dimen/spacing_medium">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_profile"
                style="@style/Widget.JobLinker.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/spacing_small"
                android:text="@string/edit_profile"
                app:icon="@drawable/ic_edit"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_settings"
                style="@style/Widget.JobLinker.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/settings"
                app:icon="@drawable/ic_settings"/>

        </LinearLayout>

        <!-- My Job Listings (For Employers) -->
        <LinearLayout
            android:id="@+id/layout_my_jobs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/background"
            android:layout_marginTop="@dimen/spacing_small"
            android:padding="@dimen/spacing_medium"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="my_job_listings"
                style="@style/TextAppearance.JobLinker.HeadlineSmall"
                android:layout_marginBottom="@dimen/spacing_medium"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_my_jobs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

        </LinearLayout>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.JobLinker.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_margin="@dimen/spacing_medium"
            android:text="@string/logout"
            android:textColor="@color/error"
            app:icon="@drawable/ic_logout"
            app:iconTint="@color/error"/>

    </LinearLayout>

</ScrollView>