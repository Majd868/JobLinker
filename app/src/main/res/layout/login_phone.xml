<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Phone Number Input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_medium">

        <!-- Country Code Selector -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_country_code"
            style="@style/Widget.JobLinker.TextInputLayout"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_small"
            android:hint="Code">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_country_code"
                style="@style/Widget.JobLinker.TextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="+1"
                android:inputType="phone"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Phone Number -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_phone"
            style="@style/Widget.JobLinker.TextInputLayout"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="@string/phone_number"
            app:startIconDrawable="@drawable/ic_phone">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_phone"
                style="@style/Widget.JobLinker.TextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"/>

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Send Verification Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_send_code"
        style="@style/Widget.JobLinker.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="@string/send_verification_code"
        android:layout_marginBottom="@dimen/spacing_medium"/>

    <!-- Verification Code Input (Initially Hidden) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_verification_code"
        style="@style/Widget.JobLinker.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:hint="@string/verification_code"
        android:visibility="gone"
        app:startIconDrawable="@drawable/ic_code">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_verification_code"
            style="@style/Widget.JobLinker.TextInputEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="6"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Verify Button (Initially Hidden) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_verify"
        style="@style/Widget.JobLinker.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="@string/verify"
        android:visibility="gone"/>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/spacing_medium"
        android:visibility="gone"/>

</LinearLayout>