<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".activities.RegisterActivity">
    <!-- Add this at the bottom of your ScrollView content -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/logout"
            android:textColor="@color/error"
            android:textSize="16sp"
            app:strokeColor="@color/error"
            app:strokeWidth="2dp"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_logout"
            app:iconTint="@color/error"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

    </LinearLayout>
    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:elevation="4dp"
        app:title="@string/register"
        app:titleTextColor="@color/text_white"
        app:navigationIcon="@drawable/ic_back"/>

    <!-- Step Indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_medium"
        android:gravity="center">

        <!-- Step 1 Indicator -->
        <View
            android:id="@+id/indicator_step1"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="4dp"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:background="@color/primary"/>

        <!-- Step 2 Indicator -->
        <View
            android:id="@+id/indicator_step2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="4dp"
            android:layout_marginStart="@dimen/spacing_xs"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:background="@color/divider"/>

        <!-- Step 3 Indicator -->
        <View
            android:id="@+id/indicator_step3"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="4dp"
            android:layout_marginStart="@dimen/spacing_xs"
            android:background="@color/divider"/>

    </LinearLayout>

    <!-- ViewPager for Registration Steps -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Navigation Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_medium"
        android:background="@color/background"
        android:elevation="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.JobLinker.Button.Secondary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="@dimen/button_height"
            android:layout_marginEnd="@dimen/spacing_small"
            android:text="@string/back"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            style="@style/Widget.JobLinker.Button.Primary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="@dimen/button_height"
            android:text="@string/next"/>

    </LinearLayout>

</LinearLayout>